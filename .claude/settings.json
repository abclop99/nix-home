{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-private.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(nix-instantiate --parse *)",
      "Bash(nix-instantiate --eval *)",
      "Bash(nix eval *)",
      "Bash(nix search *)",
      "Bash(nix-env --list-generations *)",
      "Bash(nix-channel --list *)",
      "Bash(journalctl --user *)",
      "Bash(journalctl -u *)",
      "Bash(gh search *)",
      "Bash(home-manager build *)",
      "Bash(systemctl --user status *)",
      "Bash(darkman get)",
      "mcp__claude_ai_Context7__resolve-library-id",
      "mcp__claude_ai_Context7__query-docs"
    ]
  }
}
